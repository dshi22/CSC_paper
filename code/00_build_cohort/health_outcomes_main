get_hardelid_herbert <- function(bday, m_encrypted_hesid, years) {
  has_chc <- m_encrypted_hesid %in% hardelid_herbert_diagnoses[epistart >= bday - trunc(365.25 * years) &
                                                                 epistart < bday, encrypted_hesid]
  return(has_chc)
