#drop adversity, mental health, and chronic health diagnoses that occurred >2 years before the birth
get_hardelid_herbert_type <- function(bday, m_encrypted_hesid, chc_type = NULL, years) {
  if (!is.null(chc_type)) {
    has_chc <- m_encrypted_hesid %in% 
      hardelid_herbert_diagnoses[epistart >= bday - trunc(365.25 * years) &
                           epistart < bday &
                           type == chc_type]$encrypted_hesid
  } else {
    has_chc <- m_encrypted_hesid %in% 
      hardelid_herbert_diagnoses[epistart >= (bday - trunc(365.25 * years)) &
                           epistart < bday]$encrypted_hesid
  }
  return(has_chc)
}

